# Configuración General del Backend de PharmaVox
PROJECT_NAME="PharmaVox Backend"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Credenciales y Configuración de APIs de IA
# Consigue tu clave API en: https://aistudio.google.com/
GEMINI_API_KEY="tu_clave_de_gemini_api_aqui"

# Configuración del Servidor
HOST="0.0.0.0"
PORT=8000
DEBUG=True

# Base de Datos PostgreSQL (Docker / Producción)
DATABASE_URL="postgresql://postgres:postgrespassword@db:5432/pharmavox"

# Credenciales PostgreSQL para contenedor Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=pharmavox
